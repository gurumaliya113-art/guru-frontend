{
  "version": 2,
  "buildCommand": "node ./node_modules/vite/bin/vite.js build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "routes": [
    { "handle": "filesystem" },
    {
      "src": "/auth/(.*)",
      "dest": "https://guru-backend-production-8c62.up.railway.app/auth/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "https://guru-backend-production-8c62.up.railway.app/api/$1"
    },
    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ]
}